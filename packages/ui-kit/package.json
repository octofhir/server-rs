{
  "name": "@octofhir/ui-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "**/*.css",
    "**/styles.ts"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles": {
      "types": "./src/styles.ts",
      "import": "./src/styles.ts"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "fonts:sync": "node ./scripts/vendor-fonts.mjs",
    "lint": "oxlint src",
    "format": "oxlint --fix src",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@bem-react/classname": "^1.8.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "echarts": "^6.1.0",
    "final-form": "^5.0.1",
    "final-form-arrays": "^4.0.1",
    "final-form-calculate": "^2.0.0",
    "lucide-react": "^1.21.0",
    "react-final-form": "^7.0.1",
    "react-final-form-arrays": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/rubik": "^5.2.8",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "latest",
    "storybook": "^10.4.6",
    "typescript": "~6.0.3",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "dayjs": ">=1.11",
    "react": ">=19",
    "react-dom": ">=19"
  }
}
