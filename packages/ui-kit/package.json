{
  "name": "@octofhir/ui-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "**/*.css",
    "**/styles.ts"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles": {
      "types": "./src/styles.ts",
      "import": "./src/styles.ts"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "fonts:sync": "node ./scripts/vendor-fonts.mjs",
    "lint": "oxlint src",
    "format": "oxlint --fix src",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@bem-react/classname": "^1.8.0",
    "@gravity-ui/components": "^4.19.0",
    "@gravity-ui/date-components": "^3.4.2",
    "@gravity-ui/date-utils": "^2.7.0",
    "@gravity-ui/dialog-fields": "^6.0.6",
    "@gravity-ui/i18n": "^1.8.0",
    "@gravity-ui/icons": "^2.18.0",
    "@gravity-ui/navigation": "^5.0.0",
    "@gravity-ui/table": "^1.15.3",
    "@gravity-ui/uikit": "^7.38.0",
    "final-form": "^5.0.0",
    "final-form-arrays": "^4.0.0",
    "final-form-calculate": "^2.0.0",
    "lucide-react": "^1.21.0",
    "react-final-form": "^7.0.0",
    "react-final-form-arrays": "^4.0.0",
    "react-resizable-panels": "^4.11.2"
  },
  "devDependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/rubik": "^5.2.8",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4",
    "oxlint": "latest",
    "storybook": "^10.3.5",
    "typescript": "~5.9.3",
    "vite": "^7.3"
  },
  "peerDependencies": {
    "dayjs": ">=1.11",
    "react": ">=19",
    "react-dom": ">=19"
  }
}